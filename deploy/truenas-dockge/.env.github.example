# GitHub の公開 repo から直接 build します。
# branch を変える場合は末尾の #main を #ブランチ名 に変更してください。
HOIKU_PLAN_DOCS_GIT_CONTEXT=https://github.com/hoikuict/hoiku-plan-docs.git#main

# 園文例DBを置く dataset / directory に変更してください。
HOIKU_PLAN_DOCS_DATA=/mnt/main/apps/hoiku-plan-docs/data

# Cloudflare Zero Trust の tunnel token。実値は Git に入れないでください。
CLOUDFLARE_TUNNEL_TOKEN=replace-with-cloudflare-tunnel-token

# TrueNAS のLAN内で直接確認するポートです。
APP_PORT=8020

# /data dataset に書き込むコンテナユーザーです。
APP_UID=1000
APP_GID=1000
