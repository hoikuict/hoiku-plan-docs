# TrueNAS 上で git clone した hoiku-plan-docs の絶対パスに変更してください。
HOIKU_PLAN_DOCS_SOURCE=/mnt/tank/apps/hoiku-plan-docs/source

# 園文例DBを置く dataset / directory に変更してください。
HOIKU_PLAN_DOCS_DATA=/mnt/tank/apps/hoiku-plan-docs/data

# Cloudflare Zero Trust の tunnel token。実値は Git に入れないでください。
CLOUDFLARE_TUNNEL_TOKEN=replace-with-cloudflare-tunnel-token

# TrueNAS のLAN内で直接確認するポートです。
APP_PORT=8020

# /data dataset に書き込むコンテナユーザーです。既定は image 内の appuser です。
APP_UID=1000
APP_GID=1000
